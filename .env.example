# --- SERVER CONFIGURATION ---
PORT=3005
NODE_ENV=production

# --- DATABASE ---
# Ensure this URL is compatible with Vercel Postgres (e.g. valid pgbouncer or direct connection)
# Example: postgres://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# --- URL CONFIGURATION ---
# Base URL of your deployed API
BASE_URL="https://your-api-url.vercel.app"
API_URL="https://your-api-url.vercel.app/api"
BETTER_AUTH_URL="https://your-api-url.vercel.app"
BETTER_AUTH_TRUST_HOST=true

# --- FRONTEND URL ---
# URL of your deployed Frontend Next.js app
FE_URL="https://your-webapp-url.vercel.app"
ALLOWED_ORIGINS=https://your-webapp-url.vercel.app

# --- PUBLIC DOMAIN ---
# Domain without protocol
PUBLIC_DOMAIN=your-api-url.vercel.app

# --- EMAIL CONFIGURATION ---
ENABLE_EMAIL_VERIFICATION=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# --- MINIO/S3 EXTERNAL STORAGE (REQUIRED FOR VERCEL) ---
# Use Supabase Storage, Cloudflare R2, or AWS S3
MINIO_ENDPOINT="full-url-to-s3-endpoint-without-https" 
# Example for Supabase: xxxxx.supabase.co
# Example for R2: xxxxx.r2.cloudflarestorage.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_REGION="auto"
MINIO_BUCKET_NAME="e-office-srb"

# --- SSO UNDIP ---
ENABLE_SSO_UNDIP=true
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_CALLBACK_URL="https://your-api-url.vercel.app/api/auth/callback/undip"

# --- SECRETS ---
# Generate these using `openssl rand -hex 32`
JWT_SECRET=
BETTER_AUTH_SECRET=

# --- LOCK STORE ---
LOCK_STORE=postgres
