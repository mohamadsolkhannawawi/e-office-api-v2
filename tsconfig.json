{
    "compilerOptions": {
        "lib": ["ESNext"],
        "module": "NodeNext",
        "target": "ESNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "noUncheckedIndexedAccess": true,
        "baseUrl": ".",
        "paths": {
            "@backend": ["./src"],
            "@backend/*": ["./src/*"]
        }
    },
    "include": ["src", "api", "prisma"]
}
